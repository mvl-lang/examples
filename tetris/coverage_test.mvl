// coverage_test.mvl — targeted tests exercising every branch of the
// production game.mvl fns.  Complements the semantic tests in
// game_test.mvl (which use local re-declarations for isolation).
//
// The coverage tool instruments all production fns and excludes
// test-fn bodies from the denominator; calls FROM this test file
// TO game.mvl fns count for those fns' coverage.
//
// Assurance note: 0 extern blocks.

use models::{
    Shape, Rotation, Cell, Piece, Board, Bag,
    GameStatus, Command, Palette, Difficulty, Config, Game,
}
use game::{
    // Piece geometry + SRS
    piece_cells, kick_offsets, rotate_cw, rotate_ccw,
    // Board helpers
    empty_board, empty_row, cell_at, set_cell,
    // Collision
    cell_collides, piece_collides, piece_fully_inside_board,
    filled_count, row_is_full,
    // Movement
    spawn_piece, try_move, try_rotate, soft_drop, hard_drop,
    lock_piece, clear_lines,
    // Scoring + level + gravity
    score_for_clear, level_from_lines, gravity_ms, lock_delay_ms,
    // Game over
    is_game_over,
    // Bag
    refill_bag, peek_bag, advance_bag,
    // Game state
    new_game, apply_command, tick_gravity, with_bag,
}

// ── Rotation helpers ─────────────────────────────────────────────────────────

test fn cov_rotate_cw_all_states() -> Unit {
    assert_eq(rotate_cw(Rotation::R0),   Rotation::R90);
    assert_eq(rotate_cw(Rotation::R90),  Rotation::R180);
    assert_eq(rotate_cw(Rotation::R180), Rotation::R270);
    assert_eq(rotate_cw(Rotation::R270), Rotation::R0);
}

test fn cov_rotate_ccw_all_states() -> Unit {
    assert_eq(rotate_ccw(Rotation::R0),   Rotation::R270);
    assert_eq(rotate_ccw(Rotation::R90),  Rotation::R0);
    assert_eq(rotate_ccw(Rotation::R180), Rotation::R90);
    assert_eq(rotate_ccw(Rotation::R270), Rotation::R180);
}

// ── Board helpers ────────────────────────────────────────────────────────────

test fn cov_empty_row_len() -> Unit { assert_eq(empty_row().len(), 10) }
test fn cov_empty_board_filled_count() -> Unit { assert_eq(filled_count(empty_board()), 0) }

test fn cov_cell_at_in_bounds() -> Unit {
    match cell_at(empty_board(), 5, 5) {
        Cell::Empty     => assert_eq(1, 1),
        Cell::Filled(_) => assert_eq(1, 0),
    }
}

test fn cov_cell_at_negative_row() -> Unit {
    match cell_at(empty_board(), -1, 5) {
        Cell::Empty     => assert_eq(1, 1),
        Cell::Filled(_) => assert_eq(1, 0),
    }
}

test fn cov_cell_at_high_row() -> Unit {
    match cell_at(empty_board(), 20, 5) {
        Cell::Empty     => assert_eq(1, 1),
        Cell::Filled(_) => assert_eq(1, 0),
    }
}

test fn cov_cell_at_negative_col() -> Unit {
    match cell_at(empty_board(), 5, -1) {
        Cell::Empty     => assert_eq(1, 1),
        Cell::Filled(_) => assert_eq(1, 0),
    }
}

test fn cov_cell_at_high_col() -> Unit {
    match cell_at(empty_board(), 5, 10) {
        Cell::Empty     => assert_eq(1, 1),
        Cell::Filled(_) => assert_eq(1, 0),
    }
}

test fn cov_set_cell_in_bounds() -> Unit {
    assert_eq(filled_count(set_cell(empty_board(), 5, 5, Cell::Filled(Shape::T))), 1)
}

test fn cov_set_cell_row_neg() -> Unit {
    assert_eq(filled_count(set_cell(empty_board(), -1, 5, Cell::Filled(Shape::T))), 0)
}

test fn cov_set_cell_row_high() -> Unit {
    assert_eq(filled_count(set_cell(empty_board(), 20, 5, Cell::Filled(Shape::T))), 0)
}

test fn cov_set_cell_col_neg() -> Unit {
    assert_eq(filled_count(set_cell(empty_board(), 5, -1, Cell::Filled(Shape::T))), 0)
}

test fn cov_set_cell_col_high() -> Unit {
    assert_eq(filled_count(set_cell(empty_board(), 5, 10, Cell::Filled(Shape::T))), 0)
}

// ── Collision detection ──────────────────────────────────────────────────────

test fn cov_cell_collides_wall_left()  -> Unit { assert_eq(cell_collides(empty_board(), 10, -1), true) }
test fn cov_cell_collides_wall_right() -> Unit { assert_eq(cell_collides(empty_board(), 10, 10), true) }
test fn cov_cell_collides_floor()      -> Unit { assert_eq(cell_collides(empty_board(), 20,  5), true) }
test fn cov_cell_collides_above()      -> Unit { assert_eq(cell_collides(empty_board(), -1,  5), false) }
test fn cov_cell_collides_empty_cell() -> Unit { assert_eq(cell_collides(empty_board(),  5,  5), false) }

test fn cov_cell_collides_filled_cell() -> Unit {
    let b: Board = set_cell(empty_board(), 5, 5, Cell::Filled(Shape::I));
    assert_eq(cell_collides(b, 5, 5), true);
}

test fn cov_piece_collides_free() -> Unit {
    assert_eq(piece_collides(spawn_piece(Shape::T), empty_board()), false)
}

test fn cov_piece_fully_inside_spawn() -> Unit {
    // Spawn straddles rows -1 and 0 — NOT fully inside the visible board.
    assert_eq(piece_fully_inside_board(spawn_piece(Shape::T)), false)
}

test fn cov_piece_fully_inside_bottom() -> Unit {
    let p: Piece = Piece {
        shape: Shape::O, rotation: Rotation::R0, row: 18, col: 4,
    };
    assert_eq(piece_fully_inside_board(p), true)
}

// ── Row / clear helpers ──────────────────────────────────────────────────────

test fn cov_row_is_full_empty() -> Unit { assert_eq(row_is_full(empty_row()), false) }

test fn cov_row_is_full_full() -> Unit {
    let full: List[Cell] = List[Cell]::filled(10, Cell::Filled(Shape::I));
    assert_eq(row_is_full(full), true)
}

test fn cov_clear_lines_empty_board() -> Unit {
    assert_eq(clear_lines(empty_board()).cleared, 0)
}

// ── Piece movement ───────────────────────────────────────────────────────────

test fn cov_spawn_piece_shape_i() -> Unit {
    let p: Piece = spawn_piece(Shape::I);
    assert_eq(p.row, -1);
    assert_eq(p.col,  4);
}

test fn cov_try_move_right_free() -> Unit {
    let p: Piece = spawn_piece(Shape::T);
    match try_move(p, empty_board(), 1, 0) {
        Some(_) => assert_eq(1, 1),
        None    => assert_eq(1, 0),
    }
}

test fn cov_try_move_down_free() -> Unit {
    let p: Piece = spawn_piece(Shape::T);
    match try_move(p, empty_board(), 0, 1) {
        Some(_) => assert_eq(1, 1),
        None    => assert_eq(1, 0),
    }
}

test fn cov_try_rotate_cw_free() -> Unit {
    let p: Piece = spawn_piece(Shape::T);
    match try_rotate(p, empty_board(), true) {
        Some(_) => assert_eq(1, 1),
        None    => assert_eq(1, 0),
    }
}

test fn cov_try_rotate_ccw_free() -> Unit {
    let p: Piece = spawn_piece(Shape::T);
    match try_rotate(p, empty_board(), false) {
        Some(_) => assert_eq(1, 1),
        None    => assert_eq(1, 0),
    }
}

test fn cov_soft_drop_advances() -> Unit {
    let p: Piece = spawn_piece(Shape::T);
    assert_eq(soft_drop(p, empty_board()).row, p.row + 1)
}

test fn cov_hard_drop_advances() -> Unit {
    let p: Piece = spawn_piece(Shape::T);
    let d: Piece = hard_drop(p, empty_board());
    assert_eq(d.row > p.row, true)
}

test fn cov_lock_piece_adds_four_cells() -> Unit {
    let p: Piece = Piece { shape: Shape::O, rotation: Rotation::R0, row: 18, col: 4 };
    assert_eq(filled_count(lock_piece(p, empty_board())), 4)
}

// ── Scoring ──────────────────────────────────────────────────────────────────

test fn cov_score_zero()    -> Unit { assert_eq(score_for_clear(0, 1),    0) }
test fn cov_score_single()  -> Unit { assert_eq(score_for_clear(1, 1),  100) }
test fn cov_score_double()  -> Unit { assert_eq(score_for_clear(2, 1),  300) }
test fn cov_score_triple()  -> Unit { assert_eq(score_for_clear(3, 1),  500) }
test fn cov_score_tetris()  -> Unit { assert_eq(score_for_clear(4, 1),  800) }
test fn cov_score_tetris_max_level() -> Unit { assert_eq(score_for_clear(4, 20), 16000) }

// ── Level / gravity / lock-delay ─────────────────────────────────────────────

test fn cov_level_start()     -> Unit { assert_eq(level_from_lines(0,   1),  1) }
test fn cov_level_bump()      -> Unit { assert_eq(level_from_lines(10,  1),  2) }
test fn cov_level_cap()       -> Unit { assert_eq(level_from_lines(500, 1), 20) }
test fn cov_level_start_15()  -> Unit { assert_eq(level_from_lines(0,  15), 15) }

test fn cov_gravity_l1_easy()   -> Unit { assert_eq(gravity_ms(1,  Difficulty::Easy),   1200) }
test fn cov_gravity_l1_normal() -> Unit { assert_eq(gravity_ms(1,  Difficulty::Normal),  900) }
test fn cov_gravity_l1_hard()   -> Unit { assert_eq(gravity_ms(1,  Difficulty::Hard),   800) }
test fn cov_gravity_l20_normal()-> Unit { assert_eq(gravity_ms(20, Difficulty::Normal), 100) }

test fn cov_lock_delay_easy()   -> Unit { assert_eq(lock_delay_ms(Difficulty::Easy),   500) }
test fn cov_lock_delay_normal() -> Unit { assert_eq(lock_delay_ms(Difficulty::Normal), 300) }
test fn cov_lock_delay_hard()   -> Unit { assert_eq(lock_delay_ms(Difficulty::Hard),   150) }

// ── Game-over ────────────────────────────────────────────────────────────────

test fn cov_is_game_over_free() -> Unit {
    assert_eq(is_game_over(empty_board(), spawn_piece(Shape::T)), false)
}

// ── Bag ──────────────────────────────────────────────────────────────────────

test fn cov_refill_bag_len_seven() -> Unit { assert_eq(refill_bag(42).pieces.len(), 7) }
test fn cov_refill_bag_seed_0()    -> Unit { assert_eq(refill_bag(0).pieces.len(),  7) }

test fn cov_peek_bag_full() -> Unit {
    match peek_bag(refill_bag(1)) {
        Some(_) => assert_eq(1, 1),
        None    => assert_eq(1, 0),
    }
}

test fn cov_peek_bag_empty() -> Unit {
    match peek_bag(Bag { pieces: [] }) {
        None    => assert_eq(1, 1),
        Some(_) => assert_eq(1, 0),
    }
}

test fn cov_advance_bag_drops_one() -> Unit {
    assert_eq(advance_bag(refill_bag(7)).pieces.len(), 6)
}

test fn cov_advance_bag_empty_noop() -> Unit {
    assert_eq(advance_bag(Bag { pieces: [] }).pieces.len(), 0)
}

// ── Game construction + dispatch ─────────────────────────────────────────────

total fn cov_cfg() -> Config {
    Config { palette: Palette::Color, difficulty: Difficulty::Normal, start_level: 1 }
}

test fn cov_new_game_playing() -> Unit {
    let g: Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    match g.status {
        GameStatus::Playing  => assert_eq(1, 1),
        GameStatus::Paused   => assert_eq(1, 0),
        GameStatus::GameOver => assert_eq(1, 0),
    }
}

test fn cov_apply_move_left() -> Unit {
    let g:  Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let g2: Game = apply_command(g, Command::MoveLeft);
    assert_eq(g2.current.col, 3);
}

test fn cov_apply_move_right() -> Unit {
    let g:  Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let g2: Game = apply_command(g, Command::MoveRight);
    assert_eq(g2.current.col, 5);
}

test fn cov_apply_soft_drop() -> Unit {
    let g:  Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let g2: Game = apply_command(g, Command::SoftDrop);
    assert_eq(g2.current.row >= g.current.row, true);
}

test fn cov_apply_hard_drop() -> Unit {
    let g:  Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let g2: Game = apply_command(g, Command::HardDrop);
    assert_eq(g2.current.row > g.current.row, true);
}

test fn cov_apply_rotate_cw() -> Unit {
    let g:  Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let _:  Game = apply_command(g, Command::RotateCW);
    assert_eq(1, 1);
}

test fn cov_apply_rotate_ccw() -> Unit {
    let g:  Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let _:  Game = apply_command(g, Command::RotateCCW);
    assert_eq(1, 1);
}

test fn cov_apply_pause_toggles() -> Unit {
    let g:      Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let paused: Game = apply_command(g, Command::Pause);
    match paused.status {
        GameStatus::Paused   => assert_eq(1, 1),
        GameStatus::Playing  => assert_eq(1, 0),
        GameStatus::GameOver => assert_eq(1, 0),
    }
}

test fn cov_apply_pause_resumes() -> Unit {
    let g:       Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let paused:  Game = apply_command(g,     Command::Pause);
    let resumed: Game = apply_command(paused, Command::Pause);
    match resumed.status {
        GameStatus::Playing  => assert_eq(1, 1),
        GameStatus::Paused   => assert_eq(1, 0),
        GameStatus::GameOver => assert_eq(1, 0),
    }
}

test fn cov_apply_quit_from_playing() -> Unit {
    let g:  Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let q:  Game = apply_command(g, Command::Quit);
    match q.status {
        GameStatus::GameOver => assert_eq(1, 1),
        GameStatus::Playing  => assert_eq(1, 0),
        GameStatus::Paused   => assert_eq(1, 0),
    }
}

test fn cov_apply_quit_from_paused() -> Unit {
    let g: Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let paused: Game = apply_command(g, Command::Pause);
    let quit:   Game = apply_command(paused, Command::Quit);
    match quit.status {
        GameStatus::GameOver => assert_eq(1, 1),
        GameStatus::Playing  => assert_eq(1, 0),
        GameStatus::Paused   => assert_eq(1, 0),
    }
}

test fn cov_apply_noop() -> Unit {
    let g:    Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let same: Game = apply_command(g, Command::Noop);
    assert_eq(same.current.col, g.current.col);
}

test fn cov_apply_move_from_paused_is_noop() -> Unit {
    let g:      Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let paused: Game = apply_command(g, Command::Pause);
    let still:  Game = apply_command(paused, Command::MoveLeft);
    // MoveLeft while paused is a no-op — game unchanged.
    assert_eq(still.current.col, paused.current.col);
}

test fn cov_apply_command_from_game_over_is_noop() -> Unit {
    let g:      Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let over:   Game = apply_command(g, Command::Quit);
    let still:  Game = apply_command(over, Command::MoveLeft);
    // Any command after GameOver is a no-op.
    assert_eq(still.current.col, over.current.col);
}

test fn cov_tick_gravity_descends() -> Unit {
    let g:     Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let after: Game = tick_gravity(g, Shape::O, refill_bag(2));
    assert_eq(after.current.row > g.current.row, true);
}

test fn cov_tick_gravity_paused_no_op() -> Unit {
    let g:      Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let paused: Game = apply_command(g, Command::Pause);
    let after:  Game = tick_gravity(paused, Shape::O, refill_bag(2));
    assert_eq(after.current.row, paused.current.row);
}

test fn cov_with_bag_replaces() -> Unit {
    let g:  Game = new_game(cov_cfg(), Shape::T, Shape::I, refill_bag(1));
    let g2: Game = with_bag(g, Bag { pieces: [] });
    assert_eq(g2.bag.pieces.len(), 0);
}
