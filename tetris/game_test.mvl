// ── kick_offsets table completeness ─────────────────────────────────────────

test fn test_kick_offsets_o_is_identity() -> Unit {
    assert_eq(kick_offsets(Shape::O, Rotation::R0, Rotation::R90).len(), 1);
}

test fn test_kick_offsets_i_all_transitions() -> Unit {
    assert_eq(kick_offsets(Shape::I, Rotation::R0,   Rotation::R90 ).len(), 5);
    assert_eq(kick_offsets(Shape::I, Rotation::R90,  Rotation::R0  ).len(), 5);
    assert_eq(kick_offsets(Shape::I, Rotation::R90,  Rotation::R180).len(), 5);
    assert_eq(kick_offsets(Shape::I, Rotation::R180, Rotation::R90 ).len(), 5);
    assert_eq(kick_offsets(Shape::I, Rotation::R180, Rotation::R270).len(), 5);
    assert_eq(kick_offsets(Shape::I, Rotation::R270, Rotation::R180).len(), 5);
    assert_eq(kick_offsets(Shape::I, Rotation::R270, Rotation::R0  ).len(), 5);
    assert_eq(kick_offsets(Shape::I, Rotation::R0,   Rotation::R270).len(), 5);
}

test fn test_kick_offsets_jlstz_all_transitions() -> Unit {
    assert_eq(kick_offsets(Shape::T, Rotation::R0,   Rotation::R90 ).len(), 5);
    assert_eq(kick_offsets(Shape::T, Rotation::R90,  Rotation::R0  ).len(), 5);
    assert_eq(kick_offsets(Shape::T, Rotation::R90,  Rotation::R180).len(), 5);
    assert_eq(kick_offsets(Shape::T, Rotation::R180, Rotation::R90 ).len(), 5);
    assert_eq(kick_offsets(Shape::T, Rotation::R180, Rotation::R270).len(), 5);
    assert_eq(kick_offsets(Shape::T, Rotation::R270, Rotation::R180).len(), 5);
    assert_eq(kick_offsets(Shape::T, Rotation::R270, Rotation::R0  ).len(), 5);
    assert_eq(kick_offsets(Shape::T, Rotation::R0,   Rotation::R270).len(), 5);
}

test fn test_kick_offsets_all_shapes_share_correctly() -> Unit {
    // S, Z, L, J share the JLSTZ table.
    assert_eq(kick_offsets(Shape::S, Rotation::R0, Rotation::R90).len(), 5);
    assert_eq(kick_offsets(Shape::Z, Rotation::R0, Rotation::R90).len(), 5);
    assert_eq(kick_offsets(Shape::L, Rotation::R0, Rotation::R90).len(), 5);
    assert_eq(kick_offsets(Shape::J, Rotation::R0, Rotation::R90).len(), 5);
}

// ── gameboy_ms_at_level table completeness ──────────────────────────────────

test fn test_gameboy_ms_endpoints() -> Unit {
    assert_eq(gameboy_ms_at_level(1),  900);  // GB level 0
    assert_eq(gameboy_ms_at_level(20), 100);  // GB level 19
}

test fn test_gameboy_ms_mid_levels() -> Unit {
    assert_eq(gameboy_ms_at_level(5),  620);
    assert_eq(gameboy_ms_at_level(9),  280);
    assert_eq(gameboy_ms_at_level(11), 170);
    assert_eq(gameboy_ms_at_level(14), 150);
    assert_eq(gameboy_ms_at_level(17), 130);
}

test fn test_gameboy_ms_clamps() -> Unit {
    assert_eq(gameboy_ms_at_level(0),   900);  // level < 1 clamps to 1
    assert_eq(gameboy_ms_at_level(-5),  900);
    assert_eq(gameboy_ms_at_level(100), 100);  // level > 20 clamps to 20
}

test fn test_i_r0_spans_row_1() -> Unit {
    // I-piece R0 has all 4 cells on drow=1 (SRS 4x4 bounding-box middle row).
    let cells: List[Offset] = i_r0_cells();
    let ok: Bool = cells.all(|o: Offset| o.drow == 1);
    assert_eq(ok, true);
}

// ── rotation cycles ──────────────────────────────────────────────────────────

test fn test_rotate_cw_cycles() -> Unit {
    assert_eq(rotate_cw_test(Rotation::R0),   Rotation::R90);
    assert_eq(rotate_cw_test(Rotation::R90),  Rotation::R180);
    assert_eq(rotate_cw_test(Rotation::R180), Rotation::R270);
    assert_eq(rotate_cw_test(Rotation::R270), Rotation::R0);
}

// ── board helpers ────────────────────────────────────────────────────────────

test fn test_empty_board_is_empty() -> Unit {
    let b: Board = empty_board();
    assert_eq(filled_count_test(b), 0);
    assert_eq(b.cells.len(), 20);
}

test fn test_set_cell_places_one_cell() -> Unit {
    let b: Board = board_with_cell(19, 5, Shape::T);
    assert_eq(filled_count_test(b), 1);
}

test fn test_set_cell_out_of_bounds_is_noop() -> Unit {
    let b: Board = set_cell_test(empty_board(), -1, 5, Cell::Filled(Shape::T));
    assert_eq(filled_count_test(b), 0);
}

test fn test_set_cell_row_too_high_is_noop() -> Unit {
    let b: Board = set_cell_test(empty_board(), 20, 5, Cell::Filled(Shape::T));
    assert_eq(filled_count_test(b), 0);
}

test fn test_set_cell_col_negative_is_noop() -> Unit {
    let b: Board = set_cell_test(empty_board(), 5, -1, Cell::Filled(Shape::T));
    assert_eq(filled_count_test(b), 0);
}

test fn test_set_cell_col_too_high_is_noop() -> Unit {
    let b: Board = set_cell_test(empty_board(), 5, 10, Cell::Filled(Shape::T));
    assert_eq(filled_count_test(b), 0);
}

// ── collision detection ──────────────────────────────────────────────────────

test fn test_collision_left_wall_is_wall() -> Unit {
    let b: Board = empty_board();
    // Any cell at col -1 collides.
    assert_eq(cell_collides_test(b, 10, -1), true);
}

test fn test_collision_right_wall_is_wall() -> Unit {
    let b: Board = empty_board();
    assert_eq(cell_collides_test(b, 10, 10), true);
}

test fn test_collision_floor_is_wall() -> Unit {
    let b: Board = empty_board();
    assert_eq(cell_collides_test(b, 20, 5), true);
}

test fn test_collision_above_board_is_free() -> Unit {
    let b: Board = empty_board();
    assert_eq(cell_collides_test(b, -1, 5), false);
}

test fn test_collision_filled_cell() -> Unit {
    let b: Board = board_with_cell(19, 5, Shape::I);
    assert_eq(cell_collides_test(b, 19, 5), true);
}

// ── piece collision (T at spawn row) ─────────────────────────────────────────

test fn test_t_piece_at_spawn_no_collision() -> Unit {
    // T at row=-1, col=4 in an empty board — cells at (-1,5), (0,4), (0,5), (0,6).
    // Row -1 is free (above board), row 0 is empty.
    let p: Piece = Piece { shape: Shape::T, rotation: Rotation::R0, row: -1, col: 4 };
    assert_eq(piece_collides_t_r0(p, empty_board()), false);
}

test fn test_t_piece_collides_with_stack() -> Unit {
    // Put a filled cell where the T's middle row would land.
    let b: Board = board_with_cell(19, 5, Shape::I);
    let p: Piece = Piece { shape: Shape::T, rotation: Rotation::R0, row: 18, col: 4 };
    // T's cells at (18, 5), (19, 4), (19, 5), (19, 6). (19, 5) is filled.
    assert_eq(piece_collides_t_r0(p, b), true);
}

// ── scoring ──────────────────────────────────────────────────────────────────

test fn test_score_zero_clear_awards_zero() -> Unit {
    assert_eq(score_for_clear_test(0, 5), 0);
}

test fn test_score_single_at_level_1() -> Unit {
    assert_eq(score_for_clear_test(1, 1), 100);
}

test fn test_score_double_at_level_3() -> Unit {
    assert_eq(score_for_clear_test(2, 3), 900);
}

test fn test_score_triple_at_level_5() -> Unit {
    assert_eq(score_for_clear_test(3, 5), 2500);
}

test fn test_score_tetris_at_level_20_is_16000() -> Unit {
    // requirements.md §7.9 — the actual upper bound.
    assert_eq(score_for_clear_test(4, 20), 16000);
}

// ── level progression ───────────────────────────────────────────────────────

test fn test_level_zero_lines_is_start() -> Unit {
    assert_eq(level_from_lines_test(0, 1), 1);
}

test fn test_level_ten_lines_bumps_by_one() -> Unit {
    assert_eq(level_from_lines_test(10, 1), 2);
}

test fn test_level_caps_at_twenty() -> Unit {
    assert_eq(level_from_lines_test(200, 1), 20);
}

// ── gravity ─────────────────────────────────────────────────────────────────

test fn test_gravity_level_1_easy() -> Unit {
    // Level 1 Easy = GB level 0 (900 ms) + Easy offset (300) = 1200.
    assert_eq(gravity_ms_test(1, Difficulty::Easy), 1200);
}

test fn test_gravity_level_1_normal_matches_gameboy() -> Unit {
    // Level 1 Normal is Game Boy level 0: 53 frames / 60 Hz ≈ 900 ms.
    assert_eq(gravity_ms_test(1, Difficulty::Normal), 900);
}

test fn test_gravity_level_1_hard() -> Unit {
    // Level 1 Hard = base 900 - 100 = 800.
    assert_eq(gravity_ms_test(1, Difficulty::Hard), 800);
}

test fn test_gravity_level_20_at_least_floor() -> Unit {
    let g: Int = gravity_ms_test(20, Difficulty::Normal);
    assert_eq(g >= 100, true);
    assert_eq(g <= 1200, true);
}

test fn test_gravity_monotone_easy() -> Unit {
    // Table is monotone non-increasing in level.
    let g1: Int  = gravity_ms_test(1,  Difficulty::Easy);
    let g10: Int = gravity_ms_test(10, Difficulty::Easy);
    let g20: Int = gravity_ms_test(20, Difficulty::Easy);
    assert_eq(g1 >= g10, true);
    assert_eq(g10 >= g20, true);
}

// ── row_is_full ──────────────────────────────────────────────────────────────

test fn test_row_is_full_full() -> Unit {
    assert_eq(row_is_full_test(full_row_of(Shape::I)), true);
}

test fn test_row_is_full_empty() -> Unit {
    assert_eq(row_is_full_test(empty_row()), false);
}

test fn test_row_is_full_short() -> Unit {
    // A row that isn't 10 wide is not "full" for our purposes.
    assert_eq(row_is_full_test([Cell::Filled(Shape::I), Cell::Filled(Shape::I)]), false);
}

// ── clear_lines ──────────────────────────────────────────────────────────────

test fn test_clear_lines_zero_on_empty() -> Unit {
    let r: ClearResult = clear_lines_test(empty_board());
    assert_eq(r.cleared, 0);
}

test fn test_clear_lines_single() -> Unit {
    let b: Board = board_with_bottom_row_full(Shape::I);
    let r: ClearResult = clear_lines_test(b);
    assert_eq(r.cleared, 1);
    // After clear, filled_count should be 0.
    assert_eq(filled_count_test(r.board), 0);
}

test fn test_clear_lines_tetris() -> Unit {
    // Four full rows at the bottom.
    let empties: List[List[Cell]] = List[List[Cell]]::filled(16, empty_row());
    let fulls: List[List[Cell]] = List[List[Cell]]::filled(4, full_row_of(Shape::I));
    let b: Board = Board { cells: empties.concat(fulls) };
    let r: ClearResult = clear_lines_test(b);
    assert_eq(r.cleared, 4);
    assert_eq(filled_count_test(r.board), 0);
}

test fn test_clear_lines_preserves_gaps_below() -> Unit {
    // Row 18 has one filled cell (partial), row 19 is full.
    // After clear, the partial row should still exist and slide down to row 19.
    let b1: Board = board_with_cell(18, 3, Shape::L);
    let empties: List[List[Cell]] = List[List[Cell]]::filled(19, empty_row())
        .slice(0, 18)
        .concat([b1.cells.get(18).unwrap_or(empty_row())]);
    let b: Board = Board { cells: empties.concat([full_row_of(Shape::I)]) };
    let r: ClearResult = clear_lines_test(b);
    assert_eq(r.cleared, 1);
    // Filled count should be 1 (the L cell that survived).
    assert_eq(filled_count_test(r.board), 1);
}
