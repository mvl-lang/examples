// game_test.mvl — Unit tests for pure game logic.
//
// Exercises SRS rotation, movement, line clearing, scoring, gravity,
// and game-over without a terminal.
//
// Hybrid style: legacy tests use locally-redeclared helpers
// (cell_collides_test, gravity_ms_test, etc.) — these were written
// before we imported the real fns.  Newer table-completeness tests
// (piece_cells / kick_offsets / gameboy_ms_at_level) invoke the
// production fns via `use game::...` so their branches count for
// coverage.
//
// Assurance note: 0 extern blocks.

use models::{Difficulty as ModelDifficulty}
use game::{piece_cells, kick_offsets, gameboy_ms_at_level}

// ── Type re-declarations ──────────────────────────────────────────────────────

type Shape = enum { I, O, T, S, Z, L, J }
type Rotation = enum { R0, R90, R180, R270 }
type Cell = enum { Empty, Filled(Shape) }

type Offset = struct {
    drow: Int where self >= -2 && self <= 3,
    dcol: Int where self >= -2 && self <= 3,
}

type Piece = struct {
    shape:    Shape,
    rotation: Rotation,
    row:      Int where self >= -6 && self <= 25,
    col:      Int where self >= -4 && self <= 13,
}

type Board = struct {
    cells: List[List[Cell]],
}

type ClearResult = struct {
    board:   Board,
    cleared: Int where self >= 0 && self <= 4,
}

type Difficulty = enum { Easy, Normal, Hard }

// ── Constants ─────────────────────────────────────────────────────────────────

total fn board_rows() -> Int { 20 }
total fn board_cols() -> Int { 10 }

// ── Board helpers (mirror game.mvl) ───────────────────────────────────────────

total fn empty_row() -> List[Cell] {
    List[Cell]::filled(10, Cell::Empty)
}

total fn empty_board() -> Board {
    Board { cells: List[List[Cell]]::filled(20, empty_row()) }
}

total fn full_row_of(s: Shape) -> List[Cell] {
    List[Cell]::filled(10, Cell::Filled(s))
}

total fn board_with_bottom_row_full(s: Shape) -> Board {
    let empties: List[List[Cell]] = List[List[Cell]]::filled(19, empty_row());
    Board { cells: empties.concat([full_row_of(s)]) }
}

/// Board with a single Filled cell at (row, col) and Empty elsewhere.
total fn board_with_cell(row: Int, col: Int, s: Shape) -> Board {
    set_cell_test(empty_board(), row, col, Cell::Filled(s))
}

total fn set_cell_test(board: Board, row: Int, col: Int, cell: Cell) -> Board {
    if row < 0 || row >= 20 || col < 0 || col >= 10 {
        board
    } else {
        let old_row: List[Cell] = match board.cells.get(row) {
            None => empty_row(),
            Some(r) => r,
        };
        let new_row: List[Cell] = old_row.slice(0, col)
            .concat([cell])
            .concat(old_row.slice(col + 1, 10));
        let new_cells: List[List[Cell]] = board.cells.slice(0, row)
            .concat([new_row])
            .concat(board.cells.skip(row + 1));
        Board { cells: new_cells }
    }
}

// ── Piece geometry (mirror game.mvl, condensed subset) ────────────────────────
//
// Only re-declares piece_cells arms we actually test.  The full 28-arm
// table lives in game.mvl.

total fn t_r0_cells() -> List[Offset] {
    [
        Offset { drow: 0, dcol: 1 },
        Offset { drow: 1, dcol: 0 },
        Offset { drow: 1, dcol: 1 },
        Offset { drow: 1, dcol: 2 },
    ]
}

total fn i_r0_cells() -> List[Offset] {
    [
        Offset { drow: 1, dcol: 0 },
        Offset { drow: 1, dcol: 1 },
        Offset { drow: 1, dcol: 2 },
        Offset { drow: 1, dcol: 3 },
    ]
}

total fn o_cells_test() -> List[Offset] {
    [
        Offset { drow: 0, dcol: 0 },
        Offset { drow: 0, dcol: 1 },
        Offset { drow: 1, dcol: 0 },
        Offset { drow: 1, dcol: 1 },
    ]
}

// ── Collision helper (mirror piece_collides) ──────────────────────────────────

total fn cell_collides_test(board: Board, row: Int, col: Int) -> Bool {
    if col < 0 || col >= 10 || row >= 20 {
        true
    } else if row < 0 {
        false
    } else {
        let c: Cell = match board.cells.get(row) {
            None => Cell::Empty,
            Some(r) => match r.get(col) {
                None => Cell::Empty,
                Some(x) => x,
            },
        };
        match c {
            Cell::Empty     => false,
            Cell::Filled(_) => true,
        }
    }
}

total fn piece_collides_t_r0(piece: Piece, board: Board) -> Bool {
    let cells: List[Offset] = t_r0_cells();
    let pr: Int = piece.row;
    let pc: Int = piece.col;
    cells.any(|off: Offset| cell_collides_test(board, pr + off.drow, pc + off.dcol))
}

// ── Scoring helpers (mirror game.mvl) ─────────────────────────────────────────

total fn score_for_clear_test(cleared: Int, level: Int) -> Int {
    match cleared {
        0 => 0,
        1 => 100 * level,
        2 => 300 * level,
        3 => 500 * level,
        4 => 800 * level,
        _ => 0,
    }
}

total fn level_from_lines_test(lines: Int, start_level: Int) -> Int {
    let raw: Int = start_level + lines / 10;
    if raw > 20 { 20 } else if raw < 1 { 1 } else { raw }
}

total fn gameboy_ms_at(level: Int) -> Int {
    if      level <= 1  { 900 }
    else if level <= 2  { 820 }
    else if level <= 3  { 750 }
    else if level <= 4  { 680 }
    else if level <= 5  { 620 }
    else if level <= 6  { 550 }
    else if level <= 7  { 470 }
    else if level <= 8  { 370 }
    else if level <= 9  { 280 }
    else if level <= 10 { 180 }
    else if level <= 13 { 170 }
    else if level <= 16 { 150 }
    else if level <= 19 { 130 }
    else                { 100 }
}

total fn gravity_ms_test(level: Int, difficulty: Difficulty) -> Int {
    let base: Int = gameboy_ms_at(level);
    let raw: Int = match difficulty {
        Difficulty::Easy   => base + 300,
        Difficulty::Normal => base,
        Difficulty::Hard   => if base > 200 { base - 100 } else { base },
    };
    if raw < 100 { 100 } else if raw > 1200 { 1200 } else { raw }
}

// ── Rotation helpers ──────────────────────────────────────────────────────────

total fn rotate_cw_test(r: Rotation) -> Rotation {
    match r {
        Rotation::R0   => Rotation::R90,
        Rotation::R90  => Rotation::R180,
        Rotation::R180 => Rotation::R270,
        Rotation::R270 => Rotation::R0,
    }
}

// ── Filled-count helper ───────────────────────────────────────────────────────

total fn filled_count_test(board: Board) -> Int {
    board.cells.fold(0, |acc: Int, r: List[Cell]| {
        acc + r.fold(0, |a: Int, c: Cell| match c {
            Cell::Empty     => a,
            Cell::Filled(_) => a + 1,
        })
    })
}

// ── row_is_full ──────────────────────────────────────────────────────────────

total fn row_is_full_test(row: List[Cell]) -> Bool {
    row.len() == 10 && row.all(|c: Cell| match c {
        Cell::Empty     => false,
        Cell::Filled(_) => true,
    })
}

// ── clear_lines ──────────────────────────────────────────────────────────────

total fn clear_lines_test(board: Board) -> ClearResult {
    let survivors: List[List[Cell]] = board.cells
        .filter(|r: List[Cell]| !row_is_full_test(r));
    let cleared: Int = 20 - survivors.len();
    let padding: List[List[Cell]] = List[List[Cell]]::filled(cleared, empty_row());
    let new_cells: List[List[Cell]] = padding.concat(survivors);
    let clamped: Int = if cleared < 0 { 0 } else if cleared > 4 { 4 } else { cleared };
    ClearResult { board: Board { cells: new_cells }, cleared: clamped }
}

// ═════════════════════════════════════════════════════════════════════════════
//  Tests
// ═════════════════════════════════════════════════════════════════════════════

// ── spawn geometry ───────────────────────────────────────────────────────────

test fn test_spawn_row_and_col() -> Unit {
    let p: Piece = Piece {
        shape: Shape::T, rotation: Rotation::R0,
        row: -1, col: 4,
    };
    assert_eq(p.row, -1);
    assert_eq(p.col, 4);
    assert_eq(p.rotation, Rotation::R0);
}

// ── piece_cells: bounded 4-cell tables ───────────────────────────────────────

test fn test_t_r0_has_four_cells() -> Unit {
    assert_eq(t_r0_cells().len(), 4);
}

test fn test_i_r0_has_four_cells() -> Unit {
    assert_eq(i_r0_cells().len(), 4);
}

test fn test_o_has_four_cells() -> Unit {
    assert_eq(o_cells_test().len(), 4);
}

