// examples/crud_api — full CRUD REST API over SQLite using pkg.http REST helpers.
//
// Routes:
//   GET    /health        → full health report (K8s probe)
//   GET    /health/live   → liveness probe (always 200)
//   GET    /health/ready  → readiness probe (200 if DB ok, 503 otherwise)
//   GET    /users         → list all users (JSON array)
//   POST   /users         → create user (JSON body: {name, email})
//   GET    /users/{id}    → get user by id
//   PUT    /users/{id}    → update user (JSON body: {name, email})
//   DELETE /users/{id}    → delete user
//
// Observability:
//   Metrics: Prometheus endpoint on :9090/metrics (http_requests_total, http_responses_total)
//            Served by a dedicated MetricsExporter actor on a second listener
//            (configurable via --metrics-port / CRUD_API_METRICS_PORT).
//   Tracing: Spans emitted to stderr (pkg-trace)
//   Logging: Structured logs to stderr (std.log)
//
// Config is loaded in layers: defaults → config.toml → CRUD_API_* env vars → CLI args.
// See: config.mvl and .openspec/patterns/001-config.md
//
// Usage:
//   make run                                      (defaults to 127.0.0.1:8080, /tmp/crud_api.db)
//   CRUD_API_PORT=9090 make run                   (env override)
//   ../../target/debug/mvl run main.mvl -- --port 9090 --db-path /tmp/app.db  (CLI override)
//   ../../target/debug/mvl run main.mvl -- --seed-file users.csv               (seed from CSV)
//
// Test:
//   curl -s http://127.0.0.1:8080/users | jq .
//   curl -s -X POST http://127.0.0.1:8080/users \
//        -H 'Content-Type: application/json' \
//        -d '{"name":"Alice","email":"alice@example.com"}' | jq .
//
// See #1000.
use models::{User, CreateUserRequest, UpdateUserRequest}

use config::{CrudApiConfig, ConfigLoadError, load_config}

use db::{db_open, db_init}

use seed::{db_seed_from_csv}

use handlers::{list_users_handler, get_user_handler, create_user_handler,
               update_user_handler, delete_user_handler}

use pkg.http.{HttpMethod, Request, Response, HttpError, Router, MatchedRoute, HttpStatus,
              parse_request, serialize_response, error_response,
              new_router, route, dispatch, status_code,
              method_name}

use pkg.rest.json.{json_error, http_internal_error}

use pkg.sqlite.{SqliteDb, execute, close}

use std.net.{TcpListener, TcpStream, NetError,
             tcp_listen, tcp_accept, tcp_read_request, tcp_write,
             tcp_close_listener, tcp_close_stream, net_error_msg}

use std.audit.{AuditLogger, AuditEvent, file_audit_logger, modify}

use std.io.{path, IoError}

use std.log.{Logger, default_logger, log_level_name, log_format_name}

use std.runtime.{manifest, Manifest, PackageInfo, NativeDep, NativeKind}

use pkg.trace.{Trace, Tracer, default_tracer, trace_start, span_end, span_error, TraceContext}
use pkg.health.{HealthStatus, HealthReport, ComponentHealth, make_report, health_to_response}
use pkg.metrics.{effect Metric, Metrics, new_metrics, start_prometheus_exporter}

// ── Observability effect ──────────────────────────────────────────────────────
//
// Bundles logging, audit, tracing, and metrics into a single effect alias
// for cleaner function signatures across handlers.
effect Observability > Log + Audit + Trace + Metric

// ── Composite effect ──────────────────────────────────────────────────────────
//
// Bundles all effects used by `main` into a single named alias so the
// function signature stays below the complexity-effect-width limit (max 3).
effect AppIO > DB + Env + FileRead + FileWrite + Net + Observability + Spawn

// ── Pre-listen admission ────────────────────────────────────────────────────
//
// Req 10 (Refinements) — `where` predicates carry a static guarantee that
// the literal default port falls inside the IANA-valid TCP range.
total fn validate_port_range(p: Int where p > 0 && p < 65536) -> Int { p }

fn format_packages(pkgs: List[PackageInfo]) -> String {
    let result: ref String = "";
    let first: ref Bool = true;
    for p in pkgs {
        if first {
            first = false;
            result = result.concat(p.name).concat("@").concat(p.version);
        } else {
            result = result.concat(",").concat(p.name).concat("@").concat(p.version);
        }
    }
    result
}

fn log_packages(
    val logger: Logger,
    pkgs: List[PackageInfo],
) -> Unit ! Log {
    for p in pkgs {
        logger.info("package", {"purl": p.purl})
    }
}

fn native_kind_name(k: NativeKind) -> String {
    match k {
        NativeKind::Rust => "rust",
        NativeKind::C    => "c",
    }
}

fn log_native_deps(
    val logger: Logger,
    deps: List[NativeDep],
) -> Unit ! Log {
    for d in deps {
        let intros: String = if d.introduced_by.is_empty() {
            "project"
        } else {
            join_list(d.introduced_by, ",")
        };
        logger.info("native_dep", {
            "purl":          d.purl,
            "kind":          native_kind_name(d.kind),
            "introduced_by": intros,
        })
    }
}

// ── Prometheus exporter actor ───────────────────────────────────────────────
//
// Runs the `/metrics` endpoint on a second listener so scrapers (Prometheus,
// Grafana Agent, VictoriaMetrics vmagent) can pull counters without
// interfering with the main API port. Owns its own accept loop via
// tail-recursive `serve()` — the pattern used by pkg-http's HttpServer.
//
// We intentionally re-implement the accept loop here rather than calling
// pkg-metrics' `start_prometheus_exporter`, because that helper is `partial`
// and MVL actor behaviors must be `total`. See pkg-metrics ADR-0002.

actor MetricsExporter {
    metrics:  Metrics,
    listener: TcpListener,
    logger:   Logger,

    pub fn serve() -> Unit ! Log + Net + Metric {
        match tcp_accept(self.listener) {
            Err(NetError::ConnectionReset) => self.serve(),
            Err(NetError::Timeout)         => self.serve(),
            Err(e) => {
                self.logger.error("metrics.exporter", {"error": net_error_msg(e)});
                tcp_close_listener(self.listener)
            },
            Ok(stream) => {
                // Ownership of `stream` transfers to the Metrics registry
                // actor via `serve_scrape`; it renders the Prometheus body
                // and closes the socket.
                self.metrics.serve_scrape(consume(stream));
                self.serve()
            },
        }
    }
}

// ── Router ────────────────────────────────────────────────────────────────────
//
// Pure transformation — marked `total` for termination proof.
total fn setup_router() -> Router {
    let r: Router = new_router();
    // Health endpoints (K8s probes)
    let r: Router = route(r, HttpMethod::Get, "/health", "health");
    let r: Router = route(r, HttpMethod::Get, "/health/live", "health_live");
    let r: Router = route(r, HttpMethod::Get, "/health/ready", "health_ready");
    // CRUD endpoints
    let r: Router = route(r, HttpMethod::Get, "/users", "list_users");
    let r: Router = route(r, HttpMethod::Post, "/users", "create_user");
    let r: Router = route(r, HttpMethod::Get, "/users/{id}", "get_user");
    let r: Router = route(r, HttpMethod::Put, "/users/{id}", "update_user");
    route(r, HttpMethod::Delete, "/users/{id}", "delete_user")
}

// ── Health check handlers ─────────────────────────────────────────────────────
//
// Three-endpoint pattern for K8s:
//   /health       → full report with DB component status
//   /health/live  → always 200 if process is alive
//   /health/ready → 200 if DB is reachable, 503 otherwise

/// Check if database is responsive (simple ping query).
partial fn check_db_health(val db: SqliteDb) -> Bool ! DB {
    match execute(db, "SELECT 1", []) {
        Ok(_) => true,
        Err(_) => false,
    }
}

/// Full health report with DB component check.
partial fn health_handler(
    val db: SqliteDb,
    val logger: Logger,
    version: String,
) -> Response ! DB + Log + Clock {
    let db_ok: Bool = check_db_health(db);
    let db_status: HealthStatus = if db_ok {
        HealthStatus::Healthy
    } else {
        HealthStatus::Unhealthy { reason: "database unreachable" }
    };
    let db_component: ComponentHealth = ComponentHealth {
        name: "database",
        status: db_status,
        latency_ms: None,
    };
    let overall: HealthStatus = if db_ok {
        HealthStatus::Healthy
    } else {
        HealthStatus::Unhealthy { reason: "database unreachable" }
    };
    let report: HealthReport = make_report(overall, [db_component], version);
    logger.debug("health_check", {"status": if db_ok { "healthy" } else { "unhealthy" }});
    health_to_response(report)
}

/// Liveness probe — always returns 200 if process is running.
total fn health_live_handler() -> Response {
    Response {
        status: HttpStatus::Http200Ok,
        headers: {"Content-Type": "application/json"},
        body: "{\"status\":\"alive\"}",
    }
}

/// Readiness probe — returns 200 if DB is reachable, 503 otherwise.
partial fn health_ready_handler(val db: SqliteDb) -> Response ! DB {
    let db_ok: Bool = check_db_health(db);
    if db_ok {
        Response {
            status: HttpStatus::Http200Ok,
            headers: {"Content-Type": "application/json"},
            body: "{\"status\":\"ready\"}",
        }
    } else {
        Response {
            status: HttpStatus::Http503ServiceUnavailable,
            headers: {"Content-Type": "application/json"},
            body: "{\"status\":\"not ready\",\"reason\":\"database unreachable\"}",
        }
    }
}

// ── Per-request dispatch ──────────────────────────────────────────────────────
partial fn handle_request(
    val db: SqliteDb,
    val logger: Logger,
    val auditor: AuditLogger,
    val tracer: Tracer,
    val ctx: TraceContext,
    val metrics: Metrics,
    version: String,
    req: Request,
    matched: MatchedRoute,
) -> Response ! DB + Observability {
    // Emit request counter metric
    metrics.counter_inc("http_requests_total", {"method": method_name(req.method), "route": matched.name});
    logger.debug("dispatch", {"route": matched.name, "method": method_name(req.method), "path": req.path, "trace_id": ctx.trace_id});
    let resp: Response = match matched.name {
        // Health endpoints
        "health" => health_handler(db, logger, version),
        "health_live" => health_live_handler(),
        "health_ready" => health_ready_handler(db),
        // CRUD endpoints
        "list_users" => list_users_handler(db, logger, auditor, tracer, ctx, req, matched),
        "get_user" => get_user_handler(db, logger, auditor, tracer, ctx, req, matched),
        "create_user" => create_user_handler(db, logger, auditor, tracer, ctx, req, matched),
        "update_user" => update_user_handler(db, logger, auditor, tracer, ctx, req, matched),
        "delete_user" => delete_user_handler(db, logger, auditor, tracer, ctx, req, matched),
        _ => json_error(http_internal_error("unknown route")),
    };
    // Emit response counter metric
    metrics.counter_inc("http_responses_total", {"status": status_code(resp.status).to_string(), "route": matched.name});
    resp
}

// ── Synchronous accept loop ───────────────────────────────────────────────────
//
// One connection at a time.  Sufficient for a demo; a production version would
// use actor-per-request (see examples/actor_webserver/).
//
// TcpListener is Copy so the while loop can pass it to tcp_accept each
// iteration without consuming it.  Fatal accept errors close the listener
// and return early; transient errors (reset, timeout) just continue.
partial fn process_stream(
    val db: SqliteDb,
    val logger: Logger,
    val auditor: AuditLogger,
    val tracer: Tracer,
    val router: Router,
    val metrics: Metrics,
    version: String,
    stream: TcpStream,
) -> Unit ! DB + Net + Observability {
    let req_ctx: TraceContext = trace_start("http.request");
    let resp: Response = match tcp_read_request(stream) {
        Err(e) => {
            logger.warn("read error", {"error": net_error_msg(e), "trace_id": req_ctx.trace_id});
            json_error(http_internal_error("read error"))
        },
        Ok(raw) => match parse_request(raw) {
            Err(e) => {
                logger.warn("bad_request", {"status": "400", "error": e.detail, "trace_id": req_ctx.trace_id});
                error_response(e)
            },
            Ok(req) => match dispatch(router, req) {
                Err(e) => {
                    logger.warn("not_found", {"status": status_code(e.status).to_string(), "error": e.detail, "method": method_name(req.method), "path": req.path, "trace_id": req_ctx.trace_id});
                    error_response(e)
                },
                Ok(matched) => handle_request(db, logger, auditor, tracer, req_ctx, metrics, version, req, matched),
            },
        },
    };
    match tcp_write(stream, serialize_response(resp)) {
        Ok(_) => {
            span_end(tracer, req_ctx);
            tcp_close_stream(stream)
        },
        Err(e) => {
            let emsg: String = net_error_msg(e);
            logger.error("write error", {"error": emsg, "trace_id": req_ctx.trace_id});
            span_error(tracer, req_ctx, emsg);
            tcp_close_stream(stream)
        },
    }
}

partial fn run_server_loop(
    val db: SqliteDb,
    listener: TcpListener,
    val logger: Logger,
    val auditor: AuditLogger,
    val tracer: Tracer,
    val router: Router,
    val metrics: Metrics,
    version: String,
) -> Unit ! DB + Net + Observability {
    while true {
        match tcp_accept(listener) {
            Err(NetError::ConnectionReset) => {
                logger.warn("client dropped before accept", {"reason": "connection reset"})
            },
            Err(NetError::Timeout) => {
                logger.warn("accept timed out", {"reason": "timeout"})
            },
            Err(e) => {
                logger.error("accept failed — shutting down", {"error": net_error_msg(e)});
                tcp_close_listener(listener);
                return;
            },
            Ok(stream) => process_stream(db, logger, auditor, tracer, router, metrics, version, stream),
        }
    }
}

// ── Entry point ───────────────────────────────────────────────────────────────
partial fn main() -> Unit ! AppIO {
    let _default_port_ok: Int = validate_port_range(8080);
    let cfg: CrudApiConfig = match load_config() {
        Err(_) => {
            default_logger().error("config load failed", {"reason": "see stderr"});
            return;
        },
        Ok(c) => c,
    };
    let logger: Logger = Logger { format: cfg.log_format, min_level: cfg.log_level, fd: stderr() };
    let boot_ctx: TraceContext = trace_start("service.boot");
    let m: Manifest = manifest();
    logger.info("application", {"app": m.app_name, "version": m.app_version, "built": m.build.date, "service_id": boot_ctx.trace_id});
    logger.info("versions", {"mvl": m.mvl_version, "runtime": m.runtime_version, "stdlib": m.stdlib_version});
    log_packages(logger, m.packages);
    log_native_deps(logger, m.native_deps);
    logger.info("source", {"digest": m.source_digest});

    // Start metrics exporter FIRST so scrapers can observe the boot phase
    // (DB open, seed, listen) and pick up startup counters immediately.
    let metrics: Metrics = new_metrics();
    logger.info("metrics", {"status": "initialized"});
    match tcp_listen(cfg.host, cfg.metrics_port) {
        Err(e) => logger.error("metrics.exporter", {
            "status": "listen_failed",
            "host":   cfg.host,
            "port":   cfg.metrics_port.to_string(),
            "error":  net_error_msg(e),
        }),
        Ok(metrics_listener) => {
            logger.info("metrics.exporter", {
                "status": "listening",
                "host":   cfg.host,
                "port":   cfg.metrics_port.to_string(),
                "path":   "/metrics",
            });
            let exporter: MetricsExporter = actor MetricsExporter {
                metrics:  metrics,
                listener: metrics_listener,
                logger:   logger,
            };
            exporter.serve()
        },
    }

    let db: SqliteDb = match db_open(cfg.db_path) {
        Err(msg) => {
            logger.error("db open failed", {"error": msg});
            return;
        },
        Ok(db) => db,
    };
    match db_init(db) {
        Err(msg) => {
            logger.error("db init failed", {"error": msg});
            return;
        },
        Ok(_) => { },
    }
    let router: Router = setup_router();
    let auditor: AuditLogger = file_audit_logger(path(cfg.audit_path));
    let tracer: Tracer = default_tracer();
    let _: Result[Unit, IoError] = auditor.emit(modify("system", "service", "start").with_details({"instance_id": boot_ctx.trace_id, "app": m.app_name, "version": m.app_version, "packages": format_packages(m.packages)}));
    logger.info("server", {"host": cfg.host, "port": cfg.port.to_string()});
    logger.info("logging", {"log_level": log_level_name(cfg.log_level), "log_format": log_format_name(cfg.log_format)});
    logger.info("database", {"db_path": cfg.db_path});
    logger.info("audit", {"audit_path": cfg.audit_path});

    if cfg.seed_file != "" {
        logger.info("seeding from CSV", {"path": cfg.seed_file});
        match db_seed_from_csv(db, logger, cfg.seed_file) {
            Err(msg) => logger.warn("seed failed", {"error": msg}),
            Ok(n) => logger.info("seed complete", {"rows": n.to_string()}),
        }
    } else { }
    logger.info("listening", {"status": "ready", "service_id": boot_ctx.trace_id});
    span_end(tracer, boot_ctx);
    match tcp_listen(cfg.host, cfg.port) {
        Err(e) => logger.error("listen failed", {"error": net_error_msg(e)}),
        Ok(listener) => run_server_loop(db, listener, logger, auditor, tracer, router, metrics, m.app_version),
    }
}
// Req 10: prove the literal default port lies in the valid TCP range.
// Discharged statically (Layer 1, interval) — no runtime branch emitted.
