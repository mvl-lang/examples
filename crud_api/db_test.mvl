test fn test_row_to_user_empty_email() -> Unit {
    let row: Map[String, DbValue] = {
        "id":    DbValue::Int(1),
        "name":  DbValue::Text("Alice"),
        "email": DbValue::Text(""),
    };
    match row_to_user(row) {
        Some(_) => assert_eq(1, 0),
        None    => {},
    }
}

// ── Tests: empty row ──────────────────────────────────────────────────────────

test fn test_row_to_user_empty_map() -> Unit {
    // Use a map with no matching key instead of empty literal
    let row: Map[String, DbValue] = {
        "other": DbValue::Int(0),
    };
    match row_to_user(row) {
        Some(_) => assert_eq(1, 0),
        None    => {},
    }
}
